#-----------------------------------------------
# Uncomment exactly one of the lines labelled (A), (B), and (C) below
# to switch between compilation modes.

# (A) Production use (optimized mode)
OPT ?= -O2 -DNDEBUG
# (B) Debug mode, w/ full line-level debugging symbols
# OPT ?= -g2
# (C) Profiling mode: opt, but w/debugging symbols
# OPT ?= -O2 -g2 -DNDEBUG
#-----------------------------------------------

# detect what platform we're building on
$(shell CC="$(CC)" CXX="$(CXX)" TARGET_OS="$(TARGET_OS)" \
 ./build_detect_platform build_config.mk ./)
# this file is generated by the previous line to set build flags and sources
include build_config.mk

CFLAGS += -I. -I./include $(PLATFORM_CCFLAGS) $(OPT)
CXXFLAGS += -I. -I./include $(PLATFORM_CXXFLAGS) $(OPT)

LDFLAGS += $(PLATFORM_LDFLAGS)
LIBS += $(PLATFORM_LIBS)

STATIC_OUTDIR=out-static

STATIC_LIBOBJECTS := $(addprefix $(STATIC_OUTDIR)/, $(SOURCES:.cc=.o))
STATIC_MEMENVOBJECTS := $(addprefix $(STATIC_OUTDIR)/, $(MEMENV_SOURCES:.cc=.o))

$(STATIC_OUTDIR):
	mkdir -p $@

$(STATIC_OUTDIR)/db: | $(STATIC_OUTDIR)
	mkdir -p $@

$(STATIC_OUTDIR)/helpers/memenv: | $(STATIC_OUTDIR)
	mkdir -p $@

$(STATIC_OUTDIR)/port: | $(STATIC_OUTDIR)
	mkdir -p $@

$(STATIC_OUTDIR)/table: | $(STATIC_OUTDIR)
	mkdir -p $@

$(STATIC_OUTDIR)/util: | $(STATIC_OUTDIR)
	mkdir -p $@

$(STATIC_OUTDIR)/issues: | $(STATIC_OUTDIR)
	mkdir -p $@

$(STATIC_LIBOBJECTS): | $(STATIC_OUTDIR)/db $(STATIC_OUTDIR)/port $(STATIC_OUTDIR)/table $(STATIC_OUTDIR)/util
$(STATIC_MEMENVOBJECTS): | $(STATIC_OUTDIR)/helpers/memenv

$(STATIC_OUTDIR)/libleveldb.a: $(STATIC_LIBOBJECTS)
	rm -f $@
	$(AR) -rs $@ $(STATIC_LIBOBJECTS)

$(STATIC_OUTDIR)/libmemenv.a: $(STATIC_MEMENVOBJECTS)
	rm -f $@
	$(AR) -rs $@ $(STATIC_MEMENVOBJECTS)

# Top-level targets expected by BitBlocks src/Makefile (in leveldb/ root)
libleveldb.a: $(STATIC_OUTDIR)/libleveldb.a
	cp $< $@

libmemenv.a: $(STATIC_OUTDIR)/libmemenv.a
	cp $< $@

$(STATIC_OUTDIR)/%.o: %.cc
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(STATIC_OUTDIR)/%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -rf $(STATIC_OUTDIR)
	rm -f build_config.mk libleveldb.a libmemenv.a
